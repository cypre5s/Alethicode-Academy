# 阿里云 OSS 部署配置
# 复制此文件为 .env.deploy 并填入你的配置

# OSS 地域 (香港: oss-cn-hongkong)
OSS_REGION=oss-cn-hongkong

# 阿里云 AccessKey（建议使用 RAM 子账号，只授予 OSS 权限）
OSS_ACCESS_KEY_ID=你的AccessKeyId
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret

# OSS Bucket 名称
OSS_BUCKET=你的bucket名称

# (可选) 自定义域名，绑定后填入
# OSS_CUSTOM_DOMAIN=game.yourdomain.com
